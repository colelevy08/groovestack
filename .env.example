# GrooveStack Environment Variables
# Copy this file to .env and fill in your values

# Backend server port (Railway auto-injects PORT)
SERVER_PORT=3001

# AudD API token for Vinyl Buddy track identification
AUDD_API_TOKEN=your_audd_token

# Anthropic API key for Claude vinyl verification
ANTHROPIC_API_KEY=your_anthropic_key

# Postgres connection string (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT secret for auth tokens (change in production!)
JWT_SECRET=your_jwt_secret

# API base URL (leave empty for local dev; set to Railway URL in Vercel production)
REACT_APP_API_URL=

# Production frontend URL (set in Railway for CORS)
FRONTEND_URL=
