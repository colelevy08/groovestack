# GrooveStack Environment Variables
# Copy this file to .env and fill in your values

# Backend server port
SERVER_PORT=3001

# AudD API token for Vinyl Buddy track identification
AUDD_API_TOKEN=your_audd_token

# Anthropic API key for Claude vinyl verification
ANTHROPIC_API_KEY=your_anthropic_key

# Supabase (frontend — must use REACT_APP_ prefix for CRA)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# API base URL (leave empty for local dev; set to Railway URL in production)
REACT_APP_API_URL=

# Production frontend URL (set in Railway for CORS)
FRONTEND_URL=
